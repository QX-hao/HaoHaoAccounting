# Local development example only. For production, provide strong secrets via
# environment variables or a secret manager and do not reuse these values.

# Choose one: postgres | pgsql | mysql
DB_DRIVER=postgres

# PostgreSQL DSN (default)
DB_DSN=host=127.0.0.1 user=postgres password=haohao123 dbname=haohaoaccounting port=55432 sslmode=disable TimeZone=Asia/Shanghai
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=30m

# MySQL DSN example
# DB_DRIVER=mysql
# DB_DSN=root:root@tcp(127.0.0.1:53306)/haohaoaccounting?charset=utf8mb4&parseTime=True&loc=Local

# Redis (cache for report summary and AI parse)
REDIS_ADDR=127.0.0.1:56379
REDIS_PASSWORD=haohao123
REDIS_DB=0

JWT_SECRET=haohao-dev-jwt-secret-change-me-32chars
JWT_TTL=168h
JWT_CLOCK_SKEW=30s
JWT_ISSUER=haohao-accounting
JWT_AUDIENCE=haohao-accounting-api
ADMIN_USERNAME=admin
ADMIN_PASSWORD=haohao123
ADMIN_NAME=好好用户

# Comma-separated explicit HTTP(S) origins. Do not include paths or wildcards.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Choose one: debug | release | test. Use release outside local debugging.
GIN_MODE=release
# Comma-separated proxy IPs/CIDRs that Gin may trust for X-Forwarded-* headers.
# Leave empty for direct local development. Do not use unspecified addresses, hostnames, or wildcards.
TRUSTED_PROXIES=
HTTP_READ_TIMEOUT=15s
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s
# Optional per-request context deadline. Use 0s to disable.
HTTP_REQUEST_TIMEOUT=0s
HTTP_MAX_HEADER_BYTES=1048576
HTTP_MAX_BODY_BYTES=6291456
# HSTS is disabled by default for local HTTP development. Enable only behind HTTPS.
# Preload requires max-age >= 31536000 and includeSubDomains=true.
HTTP_HSTS_MAX_AGE_SECONDS=0
HTTP_HSTS_INCLUDE_SUBDOMAINS=false
HTTP_HSTS_PRELOAD=false
LOGIN_RATE_LIMIT_MAX_FAILURES=5
LOGIN_RATE_LIMIT_WINDOW=10m
PORT=8080
